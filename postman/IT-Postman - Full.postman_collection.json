		{
			"name": "Books - GenericAdd",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (!pm.environment.has(\"counter\")) {\r",
							"    pm.environment.set(\"counter\", 1);\r",
							" }\r",
							"\r",
							"let currentCount = parseInt(pm.environment.get(\"counter\")); \r",
							"let numberOfLoops = 5;\r",
							"\r",
							"if (currentCount < numberOfLoops) {\r",
							"    postman.setNextRequest(\"Books - GenericAdd\");\r",
							"}\r",
							"else{\r",
							"    postman.setNextRequest(\"Books - Check after batch\");\r",
							"}\r",
							"\r",
							"// increment the counter and re-save the value as an environment variable\r",
							"currentCount++;\r",
							"pm.environment.set(\"counter\", currentCount);\r",
							""
						],
						"type": "text/javascript"
					}
				}
			],
